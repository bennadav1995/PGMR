# Copy this file to .env and fill in your real API keys.
# Never commit .env to version control.

OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: override entity voice (default hardcoded in server.js)
# ELEVENLABS_VOICE_ID=1rnYMVDXZksVr6x7pZPX

# Optional: server port (default 3000)
# PORT=3000

# ESP32 USB Serial bridge (server.js)
# SERIAL_PATH=/dev/cu.usbserial-0001
# SERIAL_BAUD=115200
# WebSocket: ws://localhost:8081/ws/sensors (8080 if 8081 busy)
# Override in the UI with ?ws=... or window.PGMR_LIVE_WS
